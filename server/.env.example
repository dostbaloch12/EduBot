# ===========================================
# EDUBOT BACKEND - Environment Variables
# ".env" naam se copy karें aur real values daalें
# ===========================================

# ---------- Server ----------
PORT=5000
NODE_ENV=development   # live karte waqt "production"

# ---------- 1. DATABASE (Data save) — FREE ----------
# MongoDB Atlas se free cluster banao: https://mongodb.com/atlas
# Local:  mongodb://127.0.0.1:27017/edubot
# Atlas:  mongodb+srv://USER:PASS@cluster0.xxxx.mongodb.net/edubot
MONGO_URI=mongodb://127.0.0.1:27017/edubot

# ---------- 2. JWT SECRET (security) ----------
# Banane ke liye chalayें:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=PASTE_LONG_RANDOM_STRING_HERE_32_CHARS_MINIMUM
JWT_EXPIRES_IN=7d

CLIENT_URL=http://localhost:5173

# ---------- 3. REAL OTP SMS (Twilio Verify) ----------
# https://twilio.com/console se account banao
# Phir Verify Service banao → Service SID milega
# (Twilio paisa leta hai — par naye account ko free trial credit milta hai)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_VERIFY_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---------- 4. REAL PAYMENT (JazzCash) ----------
# JazzCash merchant portal se milti hain (business account chahiye)
# https://sandbox.jazzcash.com.pk (testing) → fir live
JAZZCASH_MERCHANT_ID=
JAZZCASH_PASSWORD=
JAZZCASH_SALT=
JAZZCASH_RETURN_URL=http://localhost:5000/api/payments/callback

# ---------- 4b. EasyPaisa (optional) ----------
EASYPAISA_STORE_ID=
EASYPAISA_HASH_KEY=

# ---------- 5. REAL AI (AI Tutor + Q&A grading) ----------
# OPTION A (FREE, recommended): Google Gemini
#   https://aistudio.google.com/app/apikey se key lो (credit card nahi chahiye!)
GEMINI_API_KEY=

# OPTION B (paid): OpenAI
#   https://platform.openai.com/api-keys se key lो ($5 deposit chahiye)
OPENAI_API_KEY=

# ---------- 6. EMAIL (verification + password reset) ----------
# FREE: Resend (https://resend.com) — 3000 email/mahina muft
RESEND_API_KEY=
FROM_EMAIL=EduBot <onboarding@resend.dev>

# ---------- 7. GOOGLE LOGIN (OAuth) ----------
# https://console.cloud.google.com → OAuth Client ID banao
# (Authorized origin: aapki website URL)
GOOGLE_CLIENT_ID=

# Note: Agar koi service ki keys khali chhor dें to woh
# "dev/simulated mode" mein chalegi (testing ke liye theek).
